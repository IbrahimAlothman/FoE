# Set these as environment variables in the Railway dashboard for this
# service — do NOT commit a real .env file.

# Project Settings → API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Project Settings → API → service_role key (secret — server-only, never
# ship this to the browser/frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Railway sets PORT automatically — no need to set it yourself
